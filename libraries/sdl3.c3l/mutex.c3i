
module sdl3;

// Types
alias Condition = void;
alias Mutex = void;
alias RWLock = void;
alias Semaphore = void;

// Structs
struct InitState {
  AtomicInt status;
  ThreadID thread;
  void* reserved;
}

// Enums
enum InitStatus {
  UNINITIALIZED,
  INITIALIZING,
  INITIALIZED,
  UNINITIALIZING,
}

// Functions
extern fn void broadcastCondition(Condition* cond) @cname("SDL_BroadcastCondition");
extern fn Condition* createCondition() @cname("SDL_CreateCondition");
extern fn Mutex* createMutex() @cname("SDL_CreateMutex");
extern fn RWLock* createRWLock() @cname("SDL_CreateRWLock");
extern fn Semaphore* createSemaphore(uint initial_value) @cname("SDL_CreateSemaphore");
extern fn void destroyCondition(Condition* cond) @cname("SDL_DestroyCondition");
extern fn void destroyMutex(Mutex* mutex) @cname("SDL_DestroyMutex");
extern fn void destroyRWLock(RWLock* rwlock) @cname("SDL_DestroyRWLock");
extern fn void destroySemaphore(Semaphore* sem) @cname("SDL_DestroySemaphore");
extern fn uint getSemaphoreValue(Semaphore* sem) @cname("SDL_GetSemaphoreValue");
extern fn void lockMutex(Mutex* mutex) @cname("SDL_LockMutex");
extern fn void lockRWLockForReading(RWLock* rwlock) @cname("SDL_LockRWLockForReading");
extern fn void lockRWLockForWriting(RWLock* rwlock) @cname("SDL_LockRWLockForWriting");
extern fn void setInitialized(InitState* state, bool initialized) @cname("SDL_SetInitialized");
extern fn bool shouldInit(InitState* state) @cname("SDL_ShouldInit");
extern fn bool shouldQuit(InitState* state) @cname("SDL_ShouldQuit");
extern fn void signalCondition(Condition* cond) @cname("SDL_SignalCondition");
extern fn void signalSemaphore(Semaphore* sem) @cname("SDL_SignalCondition");
extern fn bool tryLockMutex(Mutex* mutex) @cname("SDL_TryLockMutex");
extern fn bool tryLockRWLockForReading(RWLock* rwlock) @cname("SDL_TryLockRWLockForReading");
extern fn bool tryLockRWLockForWriting(RWLock* rwlock) @cname("SDL_TryLockRWLockForWriting");
extern fn bool tryWaitSemaphore(Semaphore* sem) @cname("SDL_TryWaitSemaphore");
extern fn void unlockMutex(Mutex* mutex) @cname("SDL_UnlockMutex");
extern fn void unlockRWLock(RWLock* rwlock) @cname("SDL_UnlockRWLock");
extern fn void waitCondition(Condition* cond, Mutex *mutex) @cname("SDL_WaitCondition");
extern fn bool waitConditionTimeout(Condition* cond, Mutex* mutex, int timeoutMS) @cname("SDL_WaitConditionTimeout");
extern fn void waitSemaphore(Semaphore* sem) @cname("SDL_WaitSemaphore");
extern fn bool waitSemaphoreTimeout(Semaphore* sem, int timeoutMS) @cname("SDL_WaitSemaphoreTimeout");
