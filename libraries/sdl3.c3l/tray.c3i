
module sdl3;

// Types
typedef Tray = void;
typedef TrayEntry = void;
typedef TrayMenu = void;
alias TrayCallback = fn void(void* userdata, TrayEntry* entry);
alias TrayClickCallback = fn bool(void* userdata, Tray* tray);

// Bitstructs
bitstruct TrayEntryFlags : uint {
  bool button:    0;
  bool checkbox:  1;
  bool submenu:   2;
  bool checked:  30;
  bool disabled: 31;
}

// Functions
extern fn void clickTrayEntry(TrayEntry* entry) @cname("SDL_ClickTrayEntry");
extern fn Tray * createTray(Surface* icon, char* tooltip) @cname("SDL_CreateTray");
extern fn TrayMenu* createTrayMenu(Tray* tray) @cname("SDL_CreateTrayMenu");
extern fn TrayMenu* createTraySubmenu(TrayEntry* entry) @cname("SDL_CreateTraySubmenu");
extern fn Tray* createTrayWithProperties(PropertiesID props) @cname("SDL_CreateTrayWithProperties");
extern fn void destroyTray(Tray* tray) @cname("SDL_DestroyTray");
extern fn TrayEntry** getTrayEntries(TrayMenu* menu, int* count) @cname("SDL_GetTrayEntries");
extern fn bool getTrayEntryChecked(TrayEntry* entry) @cname("SDL_GetTrayEntryChecked");
extern fn bool getTrayEntryEnabled(TrayEntry* entry) @cname("SDL_GetTrayEntryEnabled");
extern fn char* getTrayEntryLabel(TrayEntry* entry) @cname("SDL_GetTrayEntryLabel");
extern fn TrayMenu* getTrayEntryParent(TrayEntry* entry) @cname("SDL_GetTrayEntryParent");
extern fn TrayMenu* getTrayMenu(Tray* tray) @cname("SDL_GetTrayMenu");
extern fn TrayEntry* getTrayMenuParentEntry(TrayMenu* menu) @cname("SDL_GetTrayMenuParentEntry");
extern fn Tray* getTrayMenuParentTray(TrayMenu* menu) @cname("SDL_GetTrayMenuParentTray");
extern fn TrayMenu* getTraySubmenu(TrayEntry* entry) @cname("SDL_GetTraySubmenu");
extern fn TrayEntry* insertTrayEntryAt(TrayMenu* menu, int pos, char* label, TrayEntryFlags flags) @cname("SDL_InsertTrayEntryAt");
extern fn void removeTrayEntry(TrayEntry* entry) @cname("SDL_RemoveTrayEntry");
extern fn void setTrayEntryCallback(TrayEntry* entry, TrayCallback callback, void *userdata) @cname("SDL_SetTrayEntryCallback");
extern fn void setTrayEntryChecked(TrayEntry* entry, bool checked) @cname("SDL_SetTrayEntryChecked");
extern fn void setTrayEntryEnabled(TrayEntry* entry, bool enabled) @cname("SDL_SetTrayEntryEnabled");
extern fn void setTrayEntryLabel(TrayEntry* entry, char* label) @cname("SDL_SetTrayEntryLabel");
extern fn void setTrayIcon(Tray* tray, Surface* icon) @cname("SDL_SetTrayIcon");
extern fn void setTrayTooltip(Tray* tray, char* tooltip) @cname("SDL_SetTrayTooltip");
extern fn void updateTrays() @cname("SDL_UpdateTrays");
