extern fn bool getWindowMaximumSize(SdlWindow* window, int* w, int* h) @cname("SDL_GetWindowMaximumSize");
extern fn bool getWindowMinimumSize(SdlWindow* window, int* w, int* h) @cname("SDL_GetWindowMinimumSize");
extern fn bool getWindowMouseGrab(SdlWindow* window) @cname("SDL_GetWindowMouseGrab");
