module sdl3::sdlgl;

import sdl3::stdinc;

// Types
typedef Profile = uint;
const Profile CONTEXT_PROFILE_CORE          = 0x0001;
const Profile CONTEXT_PROFILE_COMPATIBILITY = 0x0002;
const Profile CONTEXT_PROFILE_ES            = 0x0004;


// Functions
extern fn SdlGLContext createContext(SdlWindow* window) @cname("SDL_GL_CreateContext");
extern fn bool destroyContext(SdlGLContext context) @cname("SDL_GL_DestroyContext");
extern fn bool extensionSupported(char* extension) @cname("SDL_GL_ExtensionSupported");
extern fn bool getAttribute(SdlGLAttr attr, int* value) @cname("SDL_GL_GetAttribute");
extern fn SdlGLContext getCurrentContext() @cname("SDL_GL_GetCurrentContext");
extern fn SdlWindow* getCurrentWindow() @cname("SDL_GL_GetCurrentWindow");
extern fn SdlFunctionPointer getProcAddress(char* proc) @cname("SDL_GL_GetProcAddress");
extern fn bool getSwapInterval(int* interval) @cname("SDL_GL_GetSwapInterval");
extern fn bool loadLibrary(char* path) @cname("SDL_GL_LoadLibrary");
extern fn bool makeCurrent(SdlWindow* window, SdlGLContext context) @cname("SDL_GL_MakeCurrent");
extern fn void resetAttributes() @cname("SDL_GL_ResetAttributes");
extern fn bool setAttribute(SdlGLAttr attr, int value) @cname("SDL_GL_SetAttribute");
extern fn bool setSwapInterval(int interval) @cname("SDL_GL_SetSwapInterval");
extern fn bool swapWindow(SdlWindow* window) @cname("SDL_GL_SwapWindow");
extern fn void unloadLibrary() @cname("SDL_GL_UnloadLibrary");


module sdl3::egl;

import sdl3::stdinc;

extern fn SdlEGLConfig getCurrentConfig() @cname("SDL_EGL_GetCurrentConfig");
extern fn SdlEGLDisplay getCurrentDisplay() @cname("SDL_EGL_GetCurrentDisplay");
extern fn SdlFunctionPointer getProcAddress(char* proc) @cname("SDL_EGL_GetProcAddress");
extern fn SdlSurface getWindowSurface(SdlWindow* window) @cname("SDL_EGL_GetWindowSurface");
extern fn void setAttributeCallbacks(SdlEGLAttribArrayCallback platformAttribCallback, SdlEGLIntArrayCallback surfaceAttribCallback, SdlEGLIntArrayCallback contextAttribCallback, void* userdata) @cname("SDL_EGL_SetAttributeCallbacks");
