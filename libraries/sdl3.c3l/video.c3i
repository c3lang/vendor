extern fn SdlDisplayID getDisplayForWindow(SdlWindow* window) @cname("SDL_GetDisplayForWindow");
extern fn char* getDisplayName(SdlDisplayID displayID) @cname("SDL_GetDisplayName");
extern fn SdlPropertiesID getDisplayProperties(SdlDisplayID displayID) @cname("SDL_GetDisplayProperties");
extern fn SdlDisplayID* getDisplays(int* count) @cname("SDL_GetDisplays");
extern fn bool getDisplayUsableBounds(SdlDisplayID displayID, SdlRect* rect) @cname("SDL_GetDisplayUsableBounds");
extern fn SdlDisplayMode** getFullscreenDisplayModes(SdlDisplayID displayID, int* count) @cname("SDL_GetFullscreenDisplayModes");
extern fn SdlWindow* getGrabbedWindow() @cname("SDL_GetGrabbedWindow");
extern fn SdlDisplayOrientation getNaturalDisplayOrientation(SdlDisplayID displayID) @cname("SDL_GetNaturalDisplayOrientation");
extern fn int getNumVideoDrivers() @cname("SDL_GetNumVideoDrivers");
extern fn SdlDisplayID getPrimaryDisplay() @cname("SDL_GetPrimaryDisplay");
extern fn SdlSystemTheme getSystemTheme() @cname("SDL_GetSystemTheme");
extern fn char* getVideoDriver(int index) @cname("SDL_GetVideoDriver");
extern fn bool getWindowAspectRatio(SdlWindow* window, float* min_aspect, float* max_aspect) @cname("SDL_GetWindowAspectRatio");
extern fn bool getWindowBordersSize(SdlWindow* window, int* top, int* left, int* bottom, int* right) @cname("SDL_GetWindowBordersSize");
extern fn float getWindowDisplayScale(SdlWindow* window) @cname("SDL_GetWindowDisplayScale");
extern fn SdlWindowFlags getWindowFlags(SdlWindow* window) @cname("SDL_GetWindowFlags");
extern fn SdlWindow* getWindowFromID(SdlWindowID id) @cname("SDL_GetWindowFromID");
extern fn SdlDisplayMode* getWindowFullscreenMode(SdlWindow* window) @cname("SDL_GetWindowFullscreenMode");
extern fn void* getWindowICCProfile(SdlWindow* window, usz* size) @cname("SDL_GetWindowICCProfile");
extern fn SdlWindowID getWindowID(SdlWindow* window) @cname("SDL_GetWindowID");
