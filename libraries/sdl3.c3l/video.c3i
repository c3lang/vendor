extern fn bool getDisplayUsableBounds(DisplayID displayID, Rect* rect) @cname("SDL_GetDisplayUsableBounds");
extern fn DisplayMode** getFullscreenDisplayModes(DisplayID displayID, int* count) @cname("SDL_GetFullscreenDisplayModes");
extern fn Window* getGrabbedWindow() @cname("SDL_GetGrabbedWindow");
extern fn DisplayOrientation getNaturalDisplayOrientation(DisplayID displayID) @cname("SDL_GetNaturalDisplayOrientation");
extern fn int getNumVideoDrivers() @cname("SDL_GetNumVideoDrivers");
extern fn DisplayID getPrimaryDisplay() @cname("SDL_GetPrimaryDisplay");
extern fn SystemTheme getSystemTheme() @cname("SDL_GetSystemTheme");
extern fn char* getVideoDriver(int index) @cname("SDL_GetVideoDriver");
extern fn bool getWindowAspectRatio(Window* window, float* min_aspect, float* max_aspect) @cname("SDL_GetWindowAspectRatio");
extern fn bool getWindowBordersSize(Window* window, int* top, int* left, int* bottom, int* right) @cname("SDL_GetWindowBordersSize");
extern fn float getWindowDisplayScale(Window* window) @cname("SDL_GetWindowDisplayScale");
extern fn WindowFlags getWindowFlags(Window* window) @cname("SDL_GetWindowFlags");
extern fn Window* getWindowFromID(WindowID id) @cname("SDL_GetWindowFromID");
extern fn DisplayMode* getWindowFullscreenMode(Window* window) @cname("SDL_GetWindowFullscreenMode");
extern fn void* getWindowICCProfile(Window* window, usz* size) @cname("SDL_GetWindowICCProfile");
extern fn WindowID getWindowID(Window* window) @cname("SDL_GetWindowID");
