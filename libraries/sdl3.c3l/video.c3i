module sdl3::sdlgl;

// Types
alias Profile = uint;
const Profile CONTEXT_PROFILE_CORE          = 0x0001;
const Profile CONTEXT_PROFILE_COMPATIBILITY = 0x0002;
const Profile CONTEXT_PROFILE_ES            = 0x0004;

// Functions
extern fn GLContext* createContext(Window* window) @cname("SDL_GL_CreateContext");
extern fn bool destroyContext(GLContext* context) @cname("SDL_GL_DestroyContext");
extern fn bool extensionSupported(char* extension) @cname("SDL_GL_ExtensionSupported");
extern fn bool getAttribute(GLAttr attr, int* value) @cname("SDL_GL_GetAttribute");
extern fn GLContext getCurrentContext() @cname("SDL_GL_GetCurrentContext");
extern fn Window* getCurrentWindow() @cname("SDL_GL_GetCurrentWindow");
extern fn FunctionPointer getProcAddress(char* proc) @cname("SDL_GL_GetProcAddress");
extern fn bool getSwapInterval(int* interval) @cname("SDL_GL_GetSwapInterval");
extern fn bool loadLibrary(char* path) @cname("SDL_GL_LoadLibrary");
extern fn bool makeCurrent(Window* window, GLContext* context) @cname("SDL_GL_MakeCurrent");
extern fn void resetAttributes() @cname("SDL_GL_ResetAttributes");
extern fn bool setAttribute(GLAttr attr, int value) @cname("SDL_GL_SetAttribute");
extern fn bool setSwapInterval(int interval) @cname("SDL_GL_SetSwapInterval");
extern fn bool swapWindow(Window* window) @cname("SDL_GL_SwapWindow");
extern fn void unloadLibrary() @cname("SDL_GL_UnloadLibrary");


module sdl3::egl;

extern fn EGLConfig getCurrentConfig() @cname("SDL_EGL_GetCurrentConfig");
extern fn EGLDisplay getCurrentDisplay() @cname("SDL_EGL_GetCurrentDisplay");
extern fn FunctionPointer getProcAddress(char* proc) @cname("SDL_EGL_GetProcAddress");
extern fn Surface getWindowSurface(Window* window) @cname("SDL_EGL_GetWindowSurface");
extern fn void setAttributeCallbacks(
  EGLAttribArrayCallback platformAttribCallback,
  EGLIntArrayCallback surfaceAttribCallback,
  EGLIntArrayCallback contextAttribCallback,
  void* userdata) @cname("SDL_EGL_SetAttributeCallbacks");
