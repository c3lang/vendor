extern fn Window* getWindowParent(Window* window) @cname("SDL_GetWindowParent");
extern fn float getWindowPixelDensity(Window* window) @cname("SDL_GetWindowPixelDensity");
extern fn PixelFormat getWindowPixelFormat(Window* window) @cname("SDL_GetWindowPixelFormat");
extern fn bool getWindowPosition(Window* window, int* x, int* y) @cname("SDL_GetWindowPosition");
extern fn ProgressState getProgressState(Window* window) @cname("SDL_GetWindowProgressState");
extern fn float getProgressValue(Window* window) @cname("SDL_GetWindowProgressValue");
extern fn PropertiesID getWindowProperties(Window* window) @cname("SDL_GetWindowProperties");
