fn void gl_set_uniform_matrices(int loc_index, Mat4* mat, int count) @cname("rlSetUniformMatrices");    // Set shader value matrices
fn void gl_set_uniform_sampler(int loc_index, uint texture_id) @cname("rlSetUniformSampler");           // Set shader value sampler
fn void gl_set_shader(uint id, int* locs) @cname("rlSetShader");                             // Set shader currently active (id and locations)

