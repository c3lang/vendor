struct Color 
{
	char r;
	char g;
	char b;
	char a;
}

struct Palette 
{
	int nColors;
	Color* colors;
	uint version;
	int refCount;
}

struct Point 
{
	int x;
	int y;
}

struct FPoint 
{
	float x;
	float y;
}

struct Rect 
{
	int x;
	int y;
	int w;
	int h;
}

struct FRect 
{
	float x;
	float y;
	float w;
	float h;
}

